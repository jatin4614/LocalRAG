# Custom build: upstream Open WebUI + our KB extension
# Extends upstream's multi-stage pattern.

######## Frontend build ########
FROM node:22-alpine3.20 AS build
WORKDIR /app

COPY upstream/package.json upstream/package-lock.json ./
RUN npm ci --force

# Copy ALL source (including our new Svelte files + patched backend files)
COPY upstream/ .

RUN npm run build

######## Backend ########
FROM python:3.11-slim-bookworm

# Wave 1b (review §10.1): drop root. See Dockerfile.openwebui.cu128
# header comment for rationale (UID=1000 default aligns with the
# shared /var/ingest volume mapping; review §11.10).
ARG UID=1000
ARG GID=1000

ENV ENV=prod \
    PORT=8080 \
    WEBUI_AUTH=true

WORKDIR /app/backend

# System deps (matching upstream)
RUN apt-get update && apt-get install -y --no-install-recommends \
      curl gcc g++ ffmpeg pandoc netcat-openbsd \
    && rm -rf /var/lib/apt/lists/*

# Upstream Python deps
COPY upstream/backend/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir uv && \
    uv pip install --system --no-cache-dir -r requirements.txt

# Pin torch to cu121 — host GPU driver is 12.2, default upstream torch ships
# cu130 wheels which silently fall back to CPU (cuda.is_available()=False).
# cu121 is ABI-compatible with 12.x drivers and correctly detects the Ada GPU.
# Required by sentence-transformers (reranker) and any torch-using path we
# add. Installed BEFORE the rest so ucccp doesn't upgrade it transitively.
RUN uv pip install --system --no-cache-dir --index-url https://download.pytorch.org/whl/cu121 \
    'torch>=2.3,<2.6'

# Our extra Python deps (not in upstream)
# Runtime deps added by the RAG upgrade:
#   fastembed            — P1.1 hybrid BM25 (~150 MB onnxruntime + ~10 MB bm25 model on first call)
#   prometheus-client    — P2.5 /metrics endpoint
#   scikit-learn         — P3.4 RAPTOR clustering (loaded lazily only when RAG_RAPTOR=1)
#   sentence-transformers — P1.2 cross-encoder reranker (default PyPI wheels; torch pinned above)
#   transformers         — P1.5 Qwen/Gemma tokenizer for token budgeting
RUN uv pip install --system --no-cache-dir \
    pyjwt pypdf tiktoken qdrant-client httpx pydantic-settings asyncpg \
    'sqlalchemy[asyncio]' argon2-cffi python-docx openpyxl \
    fastembed prometheus-client scikit-learn \
    'sentence-transformers>=3.0' 'transformers>=4.45'

# Observability — OTel SDK + auto-instrumentors. All imports are lazy in
# ext/services/obs.py so unsetting OBS_ENABLED makes the whole stack dormant.
RUN uv pip install --system --no-cache-dir \
    'opentelemetry-api>=1.27' 'opentelemetry-sdk>=1.27' \
    'opentelemetry-exporter-otlp>=1.27' \
    'opentelemetry-instrumentation-fastapi>=0.48b0' \
    'opentelemetry-instrumentation-sqlalchemy>=0.48b0' \
    'opentelemetry-instrumentation-redis>=0.48b0' \
    'opentelemetry-instrumentation-httpx>=0.48b0' \
    'opentelemetry-instrumentation-requests>=0.48b0' \
    'opentelemetry-instrumentation-celery>=0.48b0' \
    'opentelemetry-instrumentation-logging>=0.48b0' \
    'python-json-logger>=2.0'

# Frontend build output
COPY --from=build /app/build /app/build
COPY --from=build /app/CHANGELOG.md /app/CHANGELOG.md
COPY --from=build /app/package.json /app/package.json

# Upstream backend (with our patches already applied)
COPY upstream/backend/ .

# Our extension code
COPY ext/ /app/ext/
COPY scripts/ /app/scripts/

# Wave 1b (review §10.1): create the orgchat user + drop root.
RUN groupadd -g ${GID} orgchat && useradd -u ${UID} -g ${GID} -m -s /bin/bash orgchat && \
    chown -R ${UID}:${GID} /app /app/backend 2>/dev/null || true
USER ${UID}:${GID}

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --retries=5 --start-period=120s \
  CMD curl -sf http://localhost:${PORT}/health || exit 1

CMD ["bash", "start.sh"]
