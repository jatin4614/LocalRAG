# Keep Docker build context small — only upstream/ + ext/ + scripts/ + patches/ needed
.git
.venv
.pytest_cache
.mypy_cache
.ruff_cache
__pycache__

# Large runtime dirs (NOT part of the image)
volumes/
compose/
# Wave 2 (review §10.5): celery image needs requirements-celery.txt out
# of compose/ — whitelist it back so the COPY in Dockerfile.celery works.
!compose/requirements-celery.txt
docs/
tests/
branding/
k8s/

# Model manager has its own Dockerfile
model_manager/
whisper_service/

# Editor
.idea/
.vscode/
*.swp

# Agent / session state — never include in build context
.claude/
.codex/
.cursor/

# Secrets — defense in depth (compose/.env is already filtered above, but
# protect against accidental project-root .env or .env.local)
.env
.env.*
*.pem
*.key

# Frontend build outputs (rebuilt inside the container)
node_modules/
dist/
build/
.svelte-kit/

# Operator backups (Wave 3a output, host-side only)
backups/

# Logs
*.log

# Migration artefacts that shouldn't ship
*.dump
*.sql.gz
