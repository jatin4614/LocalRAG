# Keep Docker build context small — only upstream/ + ext/ + scripts/ + patches/ needed
.git
.venv
.pytest_cache
.mypy_cache
.ruff_cache
__pycache__

# Large runtime dirs (NOT part of the image)
volumes/
compose/
docs/
tests/
branding/
k8s/

# Model manager has its own Dockerfile
model_manager/
whisper_service/

# Editor
.idea/
.vscode/
*.swp
