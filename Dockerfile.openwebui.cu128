# Custom build: upstream Open WebUI + our KB extension
# CU128 VARIANT — torch cu128 / 2.7+ for Blackwell (sm_120) GPU support.
#
# Differences from the production Dockerfile.openwebui:
#   - torch pulled from --index-url https://download.pytorch.org/whl/cu128
#   - torch pinned to >=2.7 (first release with Blackwell sm_120 kernels)
#   - sentence-transformers >=3.3 and transformers >=4.49 (torch 2.7 compat)
#
# Multi-stage layout (review §10.4) — single-stage builds carried gcc / g++
# / build-essential + pip cache + apt list cache into the runtime image
# (~1.5-2 GB waste). Now:
#   1. `frontend-build`  : node:22-alpine, builds the SvelteKit frontend.
#   2. `python-builder`  : python:3.11 + build-essential + gcc/g++,
#                          installs every Python wheel, runs the model
#                          pre-download steps (tiktoken + fastembed +
#                          ColBERT). Produces /usr/local/lib/python3.11
#                          + /opt/{tiktoken,fastembed}_cache.
#   3. final stage       : python:3.11-slim-bookworm with ONLY runtime
#                          apt deps (curl, ffmpeg, pandoc, netcat-openbsd,
#                          tesseract). Copies site-packages + model caches
#                          from the builder. No compilers, no apt cache.

######## Frontend build ########
FROM node:22-alpine3.20 AS frontend-build
WORKDIR /app

COPY upstream/package.json upstream/package-lock.json ./
RUN npm ci --force

# Copy ALL source (including our new Svelte files + patched backend files)
COPY upstream/ .

RUN npm run build

######## Python builder (compilers + pre-downloads) ########
FROM python:3.11-slim-bookworm AS python-builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app/backend

# Builder-only system deps. gcc/g++/build-essential are needed for any
# source-only Python wheels (e.g. argon2-cffi, pycrdt). Tesseract is NOT
# installed here — it's a runtime apt dep in the final stage.
RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential gcc g++ \
    && rm -rf /var/lib/apt/lists/*

# Install uv (fast resolver/installer) first.
RUN pip install --no-cache-dir uv

# Torch cu128 / 2.7+ — adds sm_120 (Blackwell RTX 50X0, RTX PRO 6000 Blackwell)
# kernel support. Host driver NVRM 580.126.09 (CUDA 12.9 capable) is forward
# compatible.
#
# Review §10.2 — install cu128 torch BEFORE upstream requirements.txt. Upstream
# requirements (transformers / sentence-transformers / etc.) transitively
# depend on torch; if installed first they pull the default CPU build from
# PyPI (~2.5 GB), which the next line then immediately overwrites with the
# cu128 wheel (~3 GB) — ~3 GB + 5 min wasted on a discarded layer. Pinning
# the cu128 wheel first means later `pip install -r requirements.txt`
# resolves it as already-satisfied (look for "Requirement already satisfied:
# torch" in the build log).
# Pin upper bound to <2.11 because torch 2.11 added a hard dep on
# nvidia-nvshmem-cu12 (~600MB wheel from pypi.nvidia.com) which has
# been intermittently un-fetchable from this host's egress (3-retry
# timeout × 125s × 2 build attempts = 4+ min of wasted build time).
# 2.7-2.10 cover sm_120 Blackwell kernel support without that dep.
# Drop the upper bound when pypi.nvidia.com stabilises OR when the
# operator pre-mirrors the wheel into a local pip index.
# 2026-05-03: bumped UV_HTTP_TIMEOUT to 600s — torch 2.10 transitively
# pulls nvidia-cusparselt-cu12 (~287 MB) from pypi.nvidia.com, which has
# been timing out on uv's default 30s. The egress is up but slow during
# build; longer timeout dodges the issue without forcing a wheel-mirror.
RUN UV_HTTP_TIMEOUT=600 uv pip install --system --no-cache-dir --index-url https://download.pytorch.org/whl/cu128 \
    'torch>=2.7,<2.11'

# Upstream Python deps — torch is now already-satisfied (cu128 wheel above).
COPY upstream/backend/requirements.txt ./requirements.txt
RUN uv pip install --system --no-cache-dir -r requirements.txt

# Our extra Python deps (not in upstream)
# Versions bumped for torch 2.7 compatibility:
#   sentence-transformers >=3.3 (torch 2.7 compat)
#   transformers          >=4.49 (torch 2.7 compat)
#   fastembed-gpu         — pulls onnxruntime-gpu w/ CUDA EP for ColBERT
#                           + sparse BM25 on GPU 1. Needs the nvidia-*-cu12
#                           runtime wheels installed below to resolve
#                           libcublasLt.so.12 / libcudnn.so.9 at dlopen.
#   prometheus-client     — unchanged
#   scikit-learn          — unchanged (RAPTOR)
RUN uv pip install --system --no-cache-dir \
    pyjwt pypdf tiktoken qdrant-client httpx pydantic-settings asyncpg \
    'sqlalchemy[asyncio]' argon2-cffi python-docx openpyxl \
    'fastembed-gpu>=0.4' prometheus-client scikit-learn \
    'sentence-transformers>=3.3' 'transformers>=4.49' \
    'celery[redis]>=5.3' 'redis>=5.0'

# Phase A — CUDA 12 runtime libs for onnxruntime-gpu's CUDA EP.
# Torch (installed above) brings its own CUDA libs but they live under a
# different path; onnxruntime probes a fixed list of names so we install
# the nvidia-*-cu12 wheels and prepend their lib dirs to LD_LIBRARY_PATH.
# Without this, fastembed-gpu's CUDAExecutionProvider silently fails to
# initialize at every embed call (the openai-API logs the dlopen error
# at WARN level then drops back to CPU).
RUN uv pip install --system --no-cache-dir \
    "nvidia-cublas-cu12" \
    "nvidia-cudnn-cu12>=9.0" \
    "nvidia-cuda-runtime-cu12" \
    "nvidia-cuda-nvrtc-cu12" \
    "nvidia-cufft-cu12" \
    "nvidia-curand-cu12"

# Plan B Phase 6.3 — OCR fallback for scanned PDFs.
# Tesseract apt package is installed in the final stage; pytesseract is the
# Python binding, pymupdf rasterizes pages, pillow handles the in-memory
# image. Cloud backends (boto3, google-cloud-documentai) are NOT installed
# by default — operators must opt in per ext/services/ocr.py +
# docs/runbook/ocr-runbook.md.
RUN uv pip install --system --no-cache-dir \
    pytesseract==0.3.13 \
    pymupdf==1.24.10 \
    pillow==10.4.0

# Observability — OTel SDK + auto-instrumentors. All imports are lazy in
# ext/services/obs.py so unsetting OBS_ENABLED makes the whole stack dormant.
RUN uv pip install --system --no-cache-dir \
    'opentelemetry-api>=1.27' 'opentelemetry-sdk>=1.27' \
    'opentelemetry-exporter-otlp>=1.27' \
    'opentelemetry-instrumentation-fastapi>=0.48b0' \
    'opentelemetry-instrumentation-sqlalchemy>=0.48b0' \
    'opentelemetry-instrumentation-redis>=0.48b0' \
    'opentelemetry-instrumentation-httpx>=0.48b0' \
    'opentelemetry-instrumentation-requests>=0.48b0' \
    'opentelemetry-instrumentation-celery>=0.48b0' \
    'opentelemetry-instrumentation-logging>=0.48b0' \
    'python-json-logger>=2.0'

# Plan B post-merge soak fix: pre-download tiktoken encoding so the offline
# stack never tries to fetch openaipublic.blob.core.windows.net at runtime.
# Caused real production breakage (chat_rag_bridge._run_pipeline crashed
# during token-budget step → no RAG context injected → LLM answered with
# generic template). Also pre-cache o200k_base in case ever needed.
ENV TIKTOKEN_CACHE_DIR=/opt/tiktoken-cache
RUN mkdir -p /opt/tiktoken-cache && \
    python -c "import tiktoken; tiktoken.get_encoding('cl100k_base'); tiktoken.get_encoding('o200k_base')"

# Phase A — pre-download fastembed models (ColBERT + sparse BM25) into
# /opt/fastembed_cache. Mirrors Dockerfile.celery so worker + open-webui
# share the same offline contract: ingest writes colbert vectors, the
# bridge query-embeds with colbert; both code paths must work without
# reaching HuggingFace at runtime.
# Wave 2 (review §10.7): prefer BuildKit secret over ARG so the token
# never lands in image layers. Falls back to ARG=`` when the secret
# isn't mounted (anonymous download still works for these public models).
# Build with: DOCKER_BUILDKIT=1 docker build --secret id=hf_token,src=$HOME/.cache/huggingface/token ...
ARG HF_TOKEN=
ENV FASTEMBED_CACHE_PATH=/opt/fastembed_cache
RUN --mount=type=secret,id=hf_token,required=false,target=/run/secrets/hf_token \
    mkdir -p /opt/fastembed_cache && \
    HF_TOKEN="$(cat /run/secrets/hf_token 2>/dev/null || echo "${HF_TOKEN}")" python -c "\
from fastembed import LateInteractionTextEmbedding, SparseTextEmbedding;\
LateInteractionTextEmbedding(model_name='colbert-ir/colbertv2.0', cache_dir='/opt/fastembed_cache');\
SparseTextEmbedding(model_name='Qdrant/bm25', cache_dir='/opt/fastembed_cache');\
print('fastembed cache populated')"

######## Final runtime image (no compilers, no apt cache) ########
FROM python:3.11-slim-bookworm

# Wave 1b (review §10.1): drop root in the runtime image. Previous
# `ARG UID=0 / GID=0` was carried forward from upstream but never
# consumed (no useradd, no USER directive) so every container ran as
# uid=0 — a single RCE in any Python dep escalated to host-level
# write on bind mounts. Pin to 1000:1000 so the same numeric IDs
# also align with the shared /var/ingest volume between open-webui
# and celery-worker (review §11.10), and let operators override at
# build time if their host has a different conventional non-root UID.
ARG UID=1000
ARG GID=1000

ENV ENV=prod \
    PORT=8080 \
    WEBUI_AUTH=true \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app/backend

# Runtime apt deps only. gcc/g++/build-essential are NOT installed (they
# lived in python-builder). Tesseract OCR baseline (en) is shipped here;
# multilingual language packs are added in a separate commit (§10.9).
RUN apt-get update && apt-get install -y --no-install-recommends \
      curl ffmpeg pandoc netcat-openbsd \
      tesseract-ocr tesseract-ocr-eng \
      tesseract-ocr-fra tesseract-ocr-deu tesseract-ocr-jpn \
      tesseract-ocr-chi-sim tesseract-ocr-hin \
    && rm -rf /var/lib/apt/lists/*

# Bring the entire installed Python tree from the builder. site-packages
# under /usr/local/lib/python3.11 + console-script entrypoints under
# /usr/local/bin. The builder used --no-cache-dir so there's no pip
# wheel cache to leak through.
COPY --from=python-builder /usr/local/lib/python3.11 /usr/local/lib/python3.11
COPY --from=python-builder /usr/local/bin /usr/local/bin

# Pre-baked model caches (tiktoken encodings + fastembed ColBERT/BM25).
COPY --from=python-builder /opt/tiktoken-cache /opt/tiktoken-cache
COPY --from=python-builder /opt/fastembed_cache /opt/fastembed_cache

ENV TIKTOKEN_CACHE_DIR=/opt/tiktoken-cache \
    FASTEMBED_CACHE_PATH=/opt/fastembed_cache

# Wire the bundled CUDA libs into LD_LIBRARY_PATH so onnxruntime's dlopen
# resolves libcublasLt.so.12 / libcudnn.so.9 / etc. without a host CUDA
# toolkit. (The nvidia-*-cu12 wheels live inside site-packages copied
# from the builder above.)
ENV LD_LIBRARY_PATH=/usr/local/lib/python3.11/site-packages/nvidia/cudnn/lib:/usr/local/lib/python3.11/site-packages/nvidia/cublas/lib:/usr/local/lib/python3.11/site-packages/nvidia/cuda_runtime/lib:/usr/local/lib/python3.11/site-packages/nvidia/cuda_nvrtc/lib:/usr/local/lib/python3.11/site-packages/nvidia/cufft/lib:/usr/local/lib/python3.11/site-packages/nvidia/curand/lib:$LD_LIBRARY_PATH

# Phase A — offline mode flags. With tiktoken + fastembed cached above
# AND the runtime bind-mount of /home/vogic/LocalRAG/volumes/hf-cache
# providing the bge-reranker-v2-m3 cache, every model load happens from
# disk. HF_HUB_OFFLINE=1 makes any escapee fail loudly at import time
# instead of silently fetching at first use.
ENV HF_HUB_OFFLINE=1 \
    TRANSFORMERS_OFFLINE=1 \
    HF_DATASETS_OFFLINE=1

# Frontend build output
COPY --from=frontend-build /app/build /app/build
COPY --from=frontend-build /app/CHANGELOG.md /app/CHANGELOG.md
COPY --from=frontend-build /app/package.json /app/package.json

# Upstream backend (with our patches already applied)
COPY upstream/backend/ .

# Our extension code
COPY ext/ /app/ext/
COPY scripts/ /app/scripts/

# Wave 1b (review §10.1): create the orgchat user + drop root. Done at
# the END so all earlier RUN/COPY layers stay root-owned (apt + pip wrote
# to /usr/local; chown on /app and /app/backend covers the writable
# runtime dirs). The chown is best-effort (`|| true`) because some paths
# may not exist on every variant of this image. Operator must rebuild +
# verify each container boots with `docker exec orgchat-open-webui id`.
RUN groupadd -g ${GID} orgchat && useradd -u ${UID} -g ${GID} -m -s /bin/bash orgchat && \
    chown -R ${UID}:${GID} /app /app/backend 2>/dev/null || true
USER ${UID}:${GID}

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --retries=5 --start-period=120s \
  CMD curl -sf http://localhost:${PORT}/health || exit 1

CMD ["bash", "start.sh"]
