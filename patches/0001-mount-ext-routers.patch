+            _kb_config = await get_kb_config_for_chat(str(_chat_id), str(_user_id))
+
+        if (_kb_config or _chat_id) and prompt and _user_id:
+            log.info("orgchat: retrieving KB sources (kbs=%d chat=%s)",
