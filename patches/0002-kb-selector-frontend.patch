@@ -0,0 +1,70 @@
+const WEBUI_API_BASE_URL = '';
+
+export const getAvailableKBs = async (token: string) => {
+	const res = await fetch(`${WEBUI_API_BASE_URL}/api/kb/available`, {
+		headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' }
+	});
+	if (!res.ok) return [];
+	return res.json();
+};
+
+export const setChatKBConfig = async (token: string, chatId: string, config: any[]) => {
+	const res = await fetch(`${WEBUI_API_BASE_URL}/api/chats/${chatId}/kb_config`, {
+		method: 'PUT',
+		headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
+		body: JSON.stringify({ config })
+	});
+	if (!res.ok) return null;
+	return res.json();
+};
+
+export const getChatKBConfig = async (token: string, chatId: string) => {
+	const res = await fetch(`${WEBUI_API_BASE_URL}/api/chats/${chatId}/kb_config`, {
+		headers: { Authorization: `Bearer ${token}` }
+	});
+	if (!res.ok) return null;
+	return res.json();
+};
+
+export const uploadKBDoc = async (token: string, kbId: number, subtagId: number, file: File) => {
+	const formData = new FormData();
+	formData.append('file', file);
+	const res = await fetch(`${WEBUI_API_BASE_URL}/api/kb/${kbId}/subtag/${subtagId}/upload`, {
+		method: 'POST',
+		headers: { Authorization: `Bearer ${token}` },
+		body: formData
+	});
+	if (!res.ok) throw new Error(`Upload failed: ${res.status}`);
+	return res.json();
+};
+
+export const uploadPrivateDoc = async (token: string, chatId: string, file: File) => {
+	const formData = new FormData();
+	formData.append('file', file);
+	const res = await fetch(`${WEBUI_API_BASE_URL}/api/chats/${chatId}/private_docs/upload`, {
+		method: 'POST',
+		headers: { Authorization: `Bearer ${token}` },
+		body: formData
+	});
+	if (!res.ok) throw new Error(`Upload failed: ${res.status}`);
+	return res.json();
+};
+
+export const ragRetrieve = async (
+	token: string,
+	chatId: string,
+	query: string,
+	kbConfig: any[]
+) => {
+	const res = await fetch(`${WEBUI_API_BASE_URL}/api/rag/retrieve`, {
+		method: 'POST',
+		headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
+		body: JSON.stringify({
+			chat_id: parseInt(chatId),
+			query,
+			selected_kb_config: kbConfig
+		})
+	});
+	if (!res.ok) return { hits: [] };
+	return res.json();
+};
diff --git a/src/lib/components/chat/KBSelector.svelte b/src/lib/components/chat/KBSelector.svelte
new file mode 100644
index 000000000..3c4c87ff2
--- /dev/null
+++ b/src/lib/components/chat/KBSelector.svelte
@@ -0,0 +1,101 @@
+<script lang="ts">
+	import { getAvailableKBs, setChatKBConfig } from '$lib/apis/kb';
+	import { onMount } from 'svelte';
+
+	export let token: string = '';
+	export let chatId: string = '';
+
+	let kbs: any[] = [];
+	let selectedKBIds: number[] = [];
+	let open = false;
+	let loading = true;
+
+	onMount(async () => {
+		if (token) {
+			try {
+				kbs = await getAvailableKBs(token);
+			} catch (e) {
+				console.warn('Failed to load KBs:', e);
+				kbs = [];
+			}
+		}
+		loading = false;
+	});
+
+	async function toggleKB(kbId: number) {
+		if (selectedKBIds.includes(kbId)) {
+			selectedKBIds = selectedKBIds.filter((id) => id !== kbId);
+		} else {
+			selectedKBIds = [...selectedKBIds, kbId];
+		}
+		if (chatId) {
+			const config = selectedKBIds.map((id) => ({ kb_id: id, subtag_ids: [] }));
+			await setChatKBConfig(token, chatId, config);
+		}
+	}
+</script>
+
+{#if kbs.length > 0}
+	<div class="relative inline-block">
+		<button
+			class="flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium rounded-lg
+				   bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700
+				   text-gray-700 dark:text-gray-300 transition-colors"
+			on:click={() => (open = !open)}
+		>
+			<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none"
+				stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
+				<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
+				<path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
+			</svg>
+			{#if selectedKBIds.length === 0}
+				Knowledge Bases
+			{:else}
+				{selectedKBIds.length} KB{selectedKBIds.length > 1 ? 's' : ''} selected
+			{/if}
+			<svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 transition-transform {open ? 'rotate-180' : ''}"
+				viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
+				<polyline points="6 9 12 15 18 9" />
+			</svg>
+		</button>
+
+		{#if open}
+			<div class="absolute left-0 mt-1 w-64 bg-white dark:bg-gray-900 rounded-lg shadow-lg
+						border border-gray-200 dark:border-gray-700 z-50 max-h-60 overflow-y-auto">
+				{#if loading}
+					<div class="p-3 text-sm text-gray-500">Loading...</div>
+				{:else if kbs.length === 0}
+					<div class="p-3 text-sm text-gray-500">No knowledge bases available</div>
+				{:else}
+					{#each kbs as kb}
+						<button
+							class="w-full flex items-center gap-2 px-3 py-2 text-left text-sm
+								   hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
+							on:click={() => toggleKB(kb.id)}
+						>
+							<div class="w-4 h-4 rounded border-2 flex items-center justify-center
+									{selectedKBIds.includes(kb.id)
+										? 'bg-blue-500 border-blue-500'
+										: 'border-gray-400 dark:border-gray-600'}">
+								{#if selectedKBIds.includes(kb.id)}
+									<svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24"
+										stroke="currentColor" stroke-width="3">
+										<polyline points="20 6 9 17 4 12" />
+									</svg>
+								{/if}
+							</div>
+							<div class="flex-1 min-w-0">
+								<div class="font-medium truncate">{kb.name}</div>
+								{#if kb.description}
+									<div class="text-xs text-gray-500 dark:text-gray-400 truncate">
+										{kb.description}
+									</div>
+								{/if}
+							</div>
+						</button>
+					{/each}
+				{/if}
+			</div>
+		{/if}
+	</div>
+{/if}
