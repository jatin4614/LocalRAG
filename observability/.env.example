# OrgChat observability stack — environment template.
# Copy to `.env` (gitignored) and fill in real values before `docker compose up`.
# Design doc: docs/superpowers/specs/2026-04-21-orgchat-observability-design.md

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

POSTGRES_HOST=orgchat-postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=openwebui

# Master switch — app-side code can read this to conditionally emit OTLP.
OBS_ENABLED=false
