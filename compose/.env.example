# --- Core ---
WEBUI_NAME=Kairos
DOMAIN=orgchat.lan
SESSION_SECRET=change-me-to-32-random-bytes

# --- Admin bootstrap ---
ADMIN_EMAIL=admin@orgchat.lan
ADMIN_PASSWORD=change-me-please

# --- Postgres ---
POSTGRES_USER=orgchat
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=orgchat
DATABASE_URL=postgresql+asyncpg://orgchat:change-me-postgres@postgres:5432/orgchat

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
# Wave 1a (review §4.1): per-request API key gate on the Qdrant REST/gRPC API.
# If empty / unset, Qdrant runs with NO auth (current default). If set, the
# qdrant container requires this header on every call AND every client (open-
# webui, celery-worker, ad-hoc operator scripts) reads the same env var to
# include it in AsyncQdrantClient init. To enable: generate with
# `openssl rand -base64 32` and uncomment.
# QDRANT_API_KEY=

# --- Models ---
# Production deploy (2026-04-26+) runs Gemma-4 31B AWQ on GPU 0 with the
# patches/vllm/gemma4_mm.py multimodal patch mounted into vllm-chat.
# To swap models: change here, then redeploy vllm-chat. Download is
# offline-safe IFF the weights are already in volumes/models/; otherwise
# unset HF_HUB_OFFLINE for the first pull.
CHAT_MODEL=QuantTrio/gemma-4-31B-it-AWQ
VISION_MODEL=Qwen/Qwen2-VL-7B-Instruct
EMBED_MODEL=BAAI/bge-m3
WHISPER_MODEL=medium

# --- Open WebUI integration ---
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=pending
ENABLE_OPENAI_API=true
OPENAI_API_BASE_URL=http://vllm-chat:8000/v1
OPENAI_API_KEY=sk-internal-dummy
ENABLE_OLLAMA_API=false
ENABLE_WEB_SEARCH=false
ENABLE_IMAGE_GENERATION=false
ENABLE_RAG_WEB_LOADER=false
AUDIO_STT_ENGINE=whisper-local
RAG_EMBEDDING_ENGINE=openai
RAG_EMBEDDING_OPENAI_API_BASE_URL=http://tei:80/v1
RAG_EMBEDDING_MODEL=BAAI/bge-m3
VECTOR_DB=qdrant

# --- Model manager ---
MODEL_MANAGER_URL=http://model-manager:8080
MODEL_UNLOAD_IDLE_SECS=300

# --- Auth bridge (Phase 5a) ---
AUTH_MODE=jwt                               # "jwt" for production, "stub" for tests
WEBUI_SECRET_KEY=change-me-to-random-bytes  # must match upstream Open WebUI's setting

# --- Ingest queue (P0.2 / Plan B Phase 6.2) ---
RAG_SYNC_INGEST=0                           # 0 = Celery queue (default after Plan B Phase 6.2 soak); 1 = legacy synchronous ingest
INGEST_BLOB_ROOT=/var/ingest                # shared filesystem blob store mount (producer + worker)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Wave 3a: backup beat schedule (review §4.2) ---
# Override the daily Qdrant snapshot cron. Empty / unset → in-code default
# (daily 02:30 UTC, offset from blob_gc's 03:17). Format is the standard
# 5-field "minute hour day_of_week month day_of_month" (Celery crontab).
# See docs/runbook/backup-restore.md.
RAG_QDRANT_SNAPSHOT_CRON=                   # e.g. "30 2 * * *" for default; leave empty to use in-code

# --- Core retrieval flags (B1 — must be passed through to open-webui + celery-worker) ---
# Without explicit env passthrough in compose, the chat process inherits
# Python module defaults that have drifted from production reality. The
# canonical operating point as of Plan A / Plan B + 2026-04-29 analyst-depth
# tuning is:
#   RAG_HYBRID=1            BM25 + dense fusion (eval winner: +12pp recall)
#   RAG_COLBERT=1           late-interaction reranker (kb_1_v4 has the named slot)
#   RAG_RERANK=1            BAAI/bge-reranker-v2-m3 on GPU 1
#   RAG_MMR=1               diversity ON (was 0) — mitigates lost-in-the-middle
#                           with the bumped top_k. Intent-conditional override
#                           still applies via _INTENT_FLAG_POLICY.
#   RAG_CONTEXT_EXPAND=1    fetch ±1 sibling chunks so each retrieved window
#                           carries surrounding paragraph context. Intent-
#                           conditional override still applies.
#   RAG_TOP_K=12            from upstream default 3 → 12. 12 × ~800-token
#   RAG_TOP_K_RERANKER=12   chunks ≈ 9.6K context, well below Gemma-4's 32K
#   RAG_RERANK_TOP_K=12     window AND below the lost-in-the-middle inflection
#                           point (~16-20K, per Databricks long-context RAG).
# Set explicitly here so that future operator overrides go through .env, not
# a code edit. Compose defaults match these values when unset.
RAG_HYBRID=1
RAG_COLBERT=1
RAG_RERANK=1
RAG_MMR=1
RAG_MMR_LAMBDA=0.7
RAG_CONTEXT_EXPAND=1
RAG_CONTEXT_EXPAND_WINDOW=1
RAG_TOP_K=12
RAG_TOP_K_RERANKER=12
RAG_RERANK_TOP_K=12
# Global-intent drill-down — for "list every X across the corpus" queries
# (chronology tables, year-spanning summaries). The level=doc pass returns
# one paraphrased summary per doc (covers all months) but lacks date-level
# detail; the drill-down adds top-K chunks per doc so the LLM sees both
# the per-doc summary AND the granular event chunks. RAG_GLOBAL_BUDGET_TOKENS
# widens the prompt budget for global intent only so the merged stream fits;
# other intents (specific / metadata / specific_date) stay at the default
# 10000-token cap.
RAG_GLOBAL_DRILLDOWN=1
RAG_GLOBAL_DRILLDOWN_K=3
RAG_GLOBAL_BUDGET_TOKENS=25000

# Token budget for non-global queries (RAG_BUDGET_TOKENS).
# Bumped from 10000 → 22000 on 2026-05-01 because multi-entity
# decomposition + context_expand siblings inflate per-hit tokens, and
# the prior budget evicted down to 3 hits on the 4-brigade query.
# Gemma-4 has a 32K context window; ~22K of retrieved content +
# ~7K system prompt + ~3K answer fits with margin.
RAG_BUDGET_TOKENS=22000

# Cap how many candidates the MMR re-embed step sends to TEI in a
# single batch. The cross-encoder upstream has already ordered the
# pool; MMR's job is to re-order the top band. With multi-entity
# decompose pulling 200+ candidates, sending all 200 to TEI alongside
# the live QU LLM + reranker on GPU 1 (24GB) OOMs. 50 fits comfortably.
# Set to 0 to disable the cap (pre-Phase-6 behaviour).
RAG_MMR_MAX_INPUT_SIZE=50

# Option B (2026-05-01) — fix the "3 hits final" cliff when MMR fails.
# When MMR soft-fails under GPU pressure, the bridge currently passes
# all 50 cross-encoder survivors to context_expand, which multiplies
# them by 3 (siblings) → 350K tokens → budget evicts to 3.
# RAG_MMR_FAIL_TRIM=1 trims to _final_k on MMR failure so only ~12
# expanded hits reach the budget cap. Default 0 = pre-fix behaviour.
RAG_MMR_FAIL_TRIM=0

# Option C (2026-05-01) — cap context_expand's input set so a large
# rerank pool doesn't trigger 50× sibling fetches. Top-N get expanded,
# remainder pass through unchanged. Default 4 — winner of A/B/C trial:
# preserves QU LLM date-filter intent, focuses sibling richness on the
# top hits, and produced the best answer on the 4-brigade query.
# Set 0 to disable (pre-fix behaviour).
RAG_CONTEXT_EXPAND_MAX_HITS=4

# Wave 2 round 4 (review §5.1) — RAG_RERANK_MIN_SCORE post-rerank floor.
# When set, hits whose post-rerank score is strictly below the threshold
# are dropped after rerank_with_flag returns. Default UNSET = OFF (no
# filter, byte-identical to pre-§5.1 behaviour). Recommend 0.05 in
# production once eval-gate confirms no >5pp recall regression. Garbage
# values (non-floats) fail open — the filter is skipped, no exception.
# RAG_RERANK_MIN_SCORE=0.05

# Wave 2 round 4 (review §5.2) — RAG_BUDGET_INCLUDES_PROMPT pre-deduct.
# When 1, budget_chunks subtracts a calibrated reserve (system prompt +
# KB catalog preamble + datetime preamble + spotlight wrap overhead per
# chunk) from RAG_BUDGET_TOKENS / RAG_GLOBAL_BUDGET_TOKENS so chunks
# don't get evicted by the LLM context overflow caused by untracked
# prompt parts. Default 0 = OFF, byte-identical to pre-§5.2 behaviour.
# Reserve breakdown: ~1500 system prompt + 800 catalog + 40 datetime
# + 30/chunk spotlight wrap. Flip to 1 once eval-gate confirms no
# top-line answer-quality regression.
RAG_BUDGET_INCLUDES_PROMPT=0

# Wave 2 round 4 (review §5.15) — total-pipeline timeout (seconds).
# Wraps the entire RAG pipeline (intent classify → RBAC → embed →
# retrieve → rerank → MMR → expand → budget → format) in
# asyncio.wait_for so a hung downstream service can't deadlock chat.
# On timeout the bridge returns degraded sources (datetime preamble only;
# catalog needs DB which may be the source of the hang) and increments
# rag_pipeline_timeout_total{intent}. Default 30s is generous; the
# 95th-percentile pipeline run is well under 5s.
RAG_TOTAL_BUDGET_SEC=30

# Phase 6.X — multi-entity decomposition (Methods 3 / 4 / 5).
# When the query enumerates >=2 entities (numbered list, bullet list, or
# "for the following: A, B, C, and D" comma-and pattern), the bridge can
# fan out into N parallel retrievals — one per entity — and merge with a
# per-entity quota floor. This fixes the "low-frequency entity gets
# evicted at the rerank cut" failure mode (32 Inf Bde case 2026-05-01).
#
# All four flags default OFF — the feature is opt-in per KB via the
# Advanced Settings panel, OR globally via these env vars. Per-KB
# rag_config wins over env (strictest-MAX merge across selected KBs).
#
#   RAG_MULTI_ENTITY_DECOMPOSE=0   master gate (Method 3)
#   RAG_ENTITY_TEXT_FILTER=0       Qdrant must.match.text per entity (Method 4)
#   RAG_QU_ENTITY_EXTRACT=0        prefer QU LLM entities over regex (Method 5)
#   RAG_MULTI_ENTITY_MIN_PER_ENTITY=10  per-entity quota floor [1, 50]
#
# Recommended initial enablement for entity-heavy KBs (military reports,
# multi-party contracts):
#   RAG_MULTI_ENTITY_DECOMPOSE=1
#   RAG_ENTITY_TEXT_FILTER=1
#   RAG_MULTI_ENTITY_MIN_PER_ENTITY=10
RAG_MULTI_ENTITY_DECOMPOSE=0
RAG_ENTITY_TEXT_FILTER=0
RAG_QU_ENTITY_EXTRACT=0
RAG_MULTI_ENTITY_MIN_PER_ENTITY=10

# Phase 6.6 — structured chunker (per-KB ingest-time switch).
# Per-KB rag_config can carry chunking_strategy="structured" to use
# chunker_structured (preserves tables/code as atomic units, segments
# on headings) instead of the default 800/100-token sliding window.
# Double-gated: BOTH the per-KB rag_config AND this env flag must be
# on for structured chunking to fire — gives operators a global
# rollback even when individual KBs are opted in.
#
# Effect: takes hold on NEXT ingest of a doc in the affected KB.
# Existing chunks already in Qdrant are untouched until re-ingested.
RAG_STRUCTURED_CHUNKER=0

# Wave 3-f review §2.5 — multilingual sentence splitter (pysbd).
# When set to 1, ext/services/chunker.py routes paragraph splitting
# through pysbd's language-specific segmenters instead of the legacy
# English-centric regex ``(?<=[.!?])\s+``. The chunker sniffs language
# cheaply from the first ~512 chars (Devanagari → ``hi``, CJK ideographs
# → ``zh``, Cyrillic → ``ru``, etc., default ``en``) and picks the
# matching pysbd Segmenter.
#
# What this catches that the regex misses:
#   * Hindi danda (``।``) — sentences in Devanagari were previously
#     concatenated into one mega-sentence.
#   * Chinese / Japanese full-stop (``。``) — same problem.
#   * Arabic / Persian terminators.
#   * False positives on French / German abbreviations (``Dr.``,
#     ``M.``, ``z.B.``) that the regex over-splits.
#
# Why default OFF: pysbd's segmentation differs from the regex by
# a few-percent of edge cases. We keep the audit trail of "what
# changed when we flipped this on" by shipping the flag off and
# requiring an opt-in flip per environment.
#
# Soft dependency: if pysbd isn't installed (e.g. air-gapped deploy
# without the wheel), the chunker silently falls back to the regex
# path. No ingest breakage. To install: ``pip install pysbd>=0.3.4``
# (already pinned in pyproject.toml + compose/requirements-celery.txt).
#
# Effect: takes hold on NEXT ingest. Existing chunks unchanged until
# re-ingested.
RAG_PYSBD_ENABLED=0

# Wave 2 (review §8.9) — Optional debug log for post-mortems.
# When set to 1, the per-request ``event=rag_query`` log line carries
# extra structured fields:
#   - ``query_text`` — the user's resolved query, truncated to 1 KB
#   - ``chunks_summary`` — top-3 hits as [{chunk_id, score, filename}]
# This makes "why did query X return wrong sources?" reproducible
# from logs alone.
#
# **PII WARNING.** ``query_text`` may contain personally identifiable
# information (names, addresses, employee references, financial data).
# Default OFF. Only flip to 1 when you have a clear retention policy
# AND a need that justifies storing user queries. Filenames in
# ``chunks_summary`` may also be sensitive — review your KB content
# before enabling.
RAG_LOG_QUERY_TEXT=0
