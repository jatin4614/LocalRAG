# --- Core ---
WEBUI_NAME=Kairos
DOMAIN=orgchat.lan
SESSION_SECRET=change-me-to-32-random-bytes

# --- Admin bootstrap ---
ADMIN_EMAIL=admin@orgchat.lan
ADMIN_PASSWORD=change-me-please

# --- Postgres ---
POSTGRES_USER=orgchat
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=orgchat
DATABASE_URL=postgresql+asyncpg://orgchat:change-me-postgres@postgres:5432/orgchat

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333

# --- Models ---
CHAT_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
VISION_MODEL=Qwen/Qwen2-VL-7B-Instruct
EMBED_MODEL=BAAI/bge-m3
WHISPER_MODEL=medium

# --- Open WebUI integration ---
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=pending
ENABLE_OPENAI_API=true
OPENAI_API_BASE_URL=http://vllm-chat:8000/v1
OPENAI_API_KEY=sk-internal-dummy
ENABLE_OLLAMA_API=false
ENABLE_WEB_SEARCH=false
ENABLE_IMAGE_GENERATION=false
ENABLE_RAG_WEB_LOADER=false
AUDIO_STT_ENGINE=whisper-local
RAG_EMBEDDING_ENGINE=openai
RAG_EMBEDDING_OPENAI_API_BASE_URL=http://tei:80/v1
RAG_EMBEDDING_MODEL=BAAI/bge-m3
VECTOR_DB=qdrant

# --- Model manager ---
MODEL_MANAGER_URL=http://model-manager:8080
MODEL_UNLOAD_IDLE_SECS=300

# --- Auth bridge (Phase 5a) ---
AUTH_MODE=jwt                               # "jwt" for production, "stub" for tests
WEBUI_SECRET_KEY=change-me-to-random-bytes  # must match upstream Open WebUI's setting

# --- Ingest queue (P0.2 / Plan B Phase 6.2) ---
RAG_SYNC_INGEST=0                           # 0 = Celery queue (default after Plan B Phase 6.2 soak); 1 = legacy synchronous ingest
INGEST_BLOB_ROOT=/var/ingest                # shared filesystem blob store mount (producer + worker)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Core retrieval flags (B1 — must be passed through to open-webui + celery-worker) ---
# Without explicit env passthrough in compose, the chat process inherits
# Python module defaults that have drifted from production reality. The
# canonical operating point as of Plan A / Plan B + 2026-04-29 analyst-depth
# tuning is:
#   RAG_HYBRID=1            BM25 + dense fusion (eval winner: +12pp recall)
#   RAG_COLBERT=1           late-interaction reranker (kb_1_v4 has the named slot)
#   RAG_RERANK=1            BAAI/bge-reranker-v2-m3 on GPU 1
#   RAG_MMR=1               diversity ON (was 0) — mitigates lost-in-the-middle
#                           with the bumped top_k. Intent-conditional override
#                           still applies via _INTENT_FLAG_POLICY.
#   RAG_CONTEXT_EXPAND=1    fetch ±1 sibling chunks so each retrieved window
#                           carries surrounding paragraph context. Intent-
#                           conditional override still applies.
#   RAG_TOP_K=12            from upstream default 3 → 12. 12 × ~800-token
#   RAG_TOP_K_RERANKER=12   chunks ≈ 9.6K context, well below Gemma-4's 32K
#   RAG_RERANK_TOP_K=12     window AND below the lost-in-the-middle inflection
#                           point (~16-20K, per Databricks long-context RAG).
# Set explicitly here so that future operator overrides go through .env, not
# a code edit. Compose defaults match these values when unset.
RAG_HYBRID=1
RAG_COLBERT=1
RAG_RERANK=1
RAG_MMR=1
RAG_MMR_LAMBDA=0.7
RAG_CONTEXT_EXPAND=1
RAG_CONTEXT_EXPAND_WINDOW=1
RAG_TOP_K=12
RAG_TOP_K_RERANKER=12
RAG_RERANK_TOP_K=12
# Global-intent drill-down — for "list every X across the corpus" queries
# (chronology tables, year-spanning summaries). The level=doc pass returns
# one paraphrased summary per doc (covers all months) but lacks date-level
# detail; the drill-down adds top-K chunks per doc so the LLM sees both
# the per-doc summary AND the granular event chunks. RAG_GLOBAL_BUDGET_TOKENS
# widens the prompt budget for global intent only so the merged stream fits;
# other intents (specific / metadata / specific_date) stay at the default
# 10000-token cap.
RAG_GLOBAL_DRILLDOWN=1
RAG_GLOBAL_DRILLDOWN_K=3
RAG_GLOBAL_BUDGET_TOKENS=25000
