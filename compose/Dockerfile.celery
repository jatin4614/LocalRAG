# Minimal Celery worker image for the ingest queue.
# Only built/run when RAG_SYNC_INGEST=0 (the async path).
FROM python:3.11-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# System deps needed by the ingest pipeline's extractors (pandoc / docx libs
# transitively + tesseract for the Plan B Phase 6.3 OCR fallback), kept tight.
RUN apt-get update && apt-get install -y --no-install-recommends \
      curl \
      pandoc \
      tesseract-ocr \
      tesseract-ocr-eng \
      tesseract-ocr-fra \
      tesseract-ocr-deu \
      tesseract-ocr-jpn \
      tesseract-ocr-chi-sim \
      tesseract-ocr-hin \
    && rm -rf /var/lib/apt/lists/*

# Runtime deps. Wave 2 (review §10.5): extracted to requirements-celery.txt
# so adding a single dep doesn't invalidate the heavy fastembed/colbert
# layer below (~30 min cold rebuild per CLAUDE.md §8).
COPY compose/requirements-celery.txt /tmp/requirements-celery.txt
RUN pip install -r /tmp/requirements-celery.txt && rm /tmp/requirements-celery.txt

# Phase A — CUDA 12 runtime libs for onnxruntime-gpu. The PyPI default
# onnxruntime-gpu wheel expects libcublasLt.so.12 / libcudnn.so.9 on
# LD_LIBRARY_PATH; without them fastembed silently drops to CPU and
# logs "Failed to load library libonnxruntime_providers_cuda.so" at
# every embed call. The nvidia-*-cu12 wheels bundle the .so files
# inside site-packages/nvidia/<lib>/lib/, and we add that prefix to
# LD_LIBRARY_PATH below so onnxruntime's dlopen finds them.
RUN pip install --no-cache-dir \
      "nvidia-cublas-cu12" \
      "nvidia-cudnn-cu12>=9.0" \
      "nvidia-cuda-runtime-cu12" \
      "nvidia-cuda-nvrtc-cu12" \
      "nvidia-cufft-cu12" \
      "nvidia-curand-cu12"

# Wire the bundled CUDA libs into LD_LIBRARY_PATH so the dynamic loader
# resolves libcublasLt.so.12 etc. without a host-side CUDA toolkit.
ENV LD_LIBRARY_PATH=/usr/local/lib/python3.11/site-packages/nvidia/cudnn/lib:/usr/local/lib/python3.11/site-packages/nvidia/cublas/lib:/usr/local/lib/python3.11/site-packages/nvidia/cuda_runtime/lib:/usr/local/lib/python3.11/site-packages/nvidia/cuda_nvrtc/lib:/usr/local/lib/python3.11/site-packages/nvidia/cufft/lib:/usr/local/lib/python3.11/site-packages/nvidia/curand/lib:$LD_LIBRARY_PATH

# Plan B post-merge soak fix: pre-download tiktoken encoding so the offline
# celery worker never tries to fetch openaipublic.blob.core.windows.net at
# runtime (caused multi-retry stalls + DLQ-bound rejects on real ingest).
ENV TIKTOKEN_CACHE_DIR=/opt/tiktoken-cache
RUN mkdir -p /opt/tiktoken-cache && \
    python -c "import tiktoken; tiktoken.get_encoding('cl100k_base'); tiktoken.get_encoding('o200k_base')"

# Phase A — pre-download fastembed models (colbert + bm25) into a stable
# cache path so the worker never reaches HuggingFace at ingest time. Both
# models are also small enough to bake into the image (colbert ~440 MB,
# bm25 ~10 MB), removing a runtime dependency on the operator's network
# and matching the air-gapped deploy contract.
#
# The token build-arg is opt-in: ``--build-arg HF_TOKEN=$(cat ~/.cache/
# huggingface/token)`` enables the download even when the host has the
# rate-limit gate up. Without it, fastembed downloads anonymously which
# works for these public models.
ARG HF_TOKEN=
ENV FASTEMBED_CACHE_PATH=/opt/fastembed_cache
RUN mkdir -p /opt/fastembed_cache && \
    HF_TOKEN="${HF_TOKEN}" python -c "\
from fastembed import LateInteractionTextEmbedding, SparseTextEmbedding;\
LateInteractionTextEmbedding(model_name='colbert-ir/colbertv2.0', cache_dir='/opt/fastembed_cache');\
SparseTextEmbedding(model_name='Qdrant/bm25', cache_dir='/opt/fastembed_cache');\
print('fastembed cache populated')"

# Offline mode: once the model caches above + tiktoken cache are baked
# into the image, set HF_HUB_OFFLINE=1 so any code path that reaches for
# huggingface_hub fails loudly instead of silently fetching at runtime.
# TRANSFORMERS_OFFLINE covers the same for transformers-based loads
# (none in this worker today, but cheap insurance for future imports).
ENV HF_HUB_OFFLINE=1 \
    TRANSFORMERS_OFFLINE=1 \
    HF_DATASETS_OFFLINE=1

# Project source. Only ext/ is needed for the worker.
COPY ext/ /app/ext/

# Wave 2 (review §10.6): worker liveness for compose healthchecks.
# `celery inspect ping` returns OK iff the worker has the broker
# connection AND its event loop is responsive. 30s interval is gentle
# (Celery's heartbeat is on the order of seconds anyway).
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD celery -A ext.workers.celery_app inspect ping || exit 1

# Entrypoint comes from the compose `command:` block (celery ... worker).
